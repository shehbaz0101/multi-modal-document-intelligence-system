# ==============================================================================
# DocIntel — .env (CPU-only + Gemini API)
# Copy to .env and set GEMINI_API_KEY.
# Get a free key at: https://aistudio.google.com/apikey
# ==============================================================================

ENV=dev
LOG_LEVEL=INFO

# --- Storage ---
STORAGE_BACKEND=local
STORAGE_ROOT=./data
STORAGE_PAGE_DPI=150

# --- Parser ---
PARSER_PRIMARY=cpu
PARSER_ENABLE_TABLE_STRUCTURE=true
PARSER_ENABLE_OCR=true

# --- Embedding (CPU) ---
EMBEDDING_TEXT_MODEL=all-MiniLM-L6-v2
EMBEDDING_TEXT_DIM=384
EMBEDDING_TEXT_BATCH_SIZE=64
EMBEDDING_VISUAL_ENABLED=false
EMBEDDING_CAPTION_MODEL=gemini-1.5-flash

# --- Indexing ---
INDEX_VECTOR_URL=http://localhost:6333
INDEX_SPARSE_URL=http://localhost:9200
INDEX_TEXT_COLLECTION=blocks_text
INDEX_SPARSE_INDEX=blocks_sparse
INDEX_METADATA_DB_URL=postgresql://docintel:docintel@localhost:5432/docintel

# --- Retrieval ---
RETRIEVAL_RRF_K=60
RETRIEVAL_RERANK_ENABLED=false

# --- Generation (Gemini) ---
# gemini-2.0-flash  : fast + cheap, great default
# gemini-2.5-pro    : best quality, use for complex documents
GENERATION_MODEL=gemini-1.5-flash
GENERATION_MAX_TOKENS=1500
GENERATION_TEMPERATURE=0.1
GEMINI_API_KEY=your_key_here             # <-- paste your key here

# --- Observability ---
OBS_TRACING_BACKEND=none
